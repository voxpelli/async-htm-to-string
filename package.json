{
  "name": "async-htm-to-string",
  "version": "5.0.2",
  "description": "Renders a htm tagged template asyncly into a string",
  "homepage": "http://github.com/voxpelli/async-htm-to-string",
  "author": "Pelle Wessman <pelle@kodfabrik.se> (http://kodfabrik.se/)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/voxpelli/async-htm-to-string.git"
  },
  "type": "module",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24",
    "typescript": ">=5.8"
  },
  "keywords": [
    "tagged template",
    "template literals",
    "htm",
    "html",
    "async",
    "asyncgenerator",
    "asynciterator",
    "asynciterable",
    "promise",
    "server-side rendering",
    "ssr"
  ],
  "files": [
    "index.d.ts.map",
    "index.d.ts",
    "index.js",
    "lib/**/*.d.ts.map",
    "lib/**/*.d.ts",
    "lib/**/*.js"
  ],
  "scripts": {
    "build:0-clean": "run-s clean",
    "build:1-declaration": "tsc -p declaration.tsconfig.json",
    "build": "run-s build:*",
    "check:1:installed-check": "installed-check --ignore tstyche",
    "check:1:knip": "knip",
    "check:1:lint": "eslint",
    "check:1:tsc": "tsc",
    "check:1:type-coverage": "type-coverage --strict --at-least 99 --ignore-files 'test/*'",
    "check:1": "run-p check:1:*",
    "check:2": "run-s build && tstyche --reporters dot,summary && run-s clean",
    "check": "run-s clean && run-p check:1:* && run-s check:2",
    "clean:declarations-top": "rm -rf $(find . -maxdepth 1 -type f -name '*.d.ts*' ! -name 'index.d.ts')",
    "clean:declarations-lib": "rm -rf $(find lib -type f -name '*.d.ts*' ! -name '*-types.d.ts')",
    "clean": "run-p clean:*",
    "prepare": "husky",
    "prepublishOnly": "run-s build",
    "test:tstyche": "run-s build && tstyche --target \"$(jq -r '.engines.typescript' package.json)\" --reporters dot,summary && run-s clean",
    "test:node": "c8 --reporter=lcov --reporter text --skip-full --check-coverage --lines 95 --branches 85 node --test --test-reporter dot test/*.spec.js",
    "test-ci": "run-s test:*",
    "test": "run-s check test:*",
    "benchmark": "node --expose-gc benchmark.js"
  },
  "dependencies": {
    "@voxpelli/typed-utils": "^4.0.0",
    "buffered-async-iterable": "^1.0.1",
    "htm": "^3.0.4"
  },
  "devDependencies": {
    "@types/node": "^20.19.30",
    "@voxpelli/eslint-config": "^23.0.0",
    "@voxpelli/tsconfig": "^16.1.0",
    "c8": "^10.1.3",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "installed-check": "^9.3.0",
    "knip": "^5.82.1",
    "mitata": "^1.0.34",
    "npm-run-all2": "^8.0.4",
    "tstyche": "^6.2.0",
    "type-coverage": "^2.29.7",
    "typescript": "~5.9.3",
    "validate-conventional-commit": "^1.0.4"
  }
}
