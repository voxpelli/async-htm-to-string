{
  "name": "async-htm-to-string",
  "workspaces": [
    "packages/*"
  ],
  "version": "4.0.0",
  "description": "Renders a htm tagged template asyncly into a string",
  "homepage": "http://github.com/voxpelli/async-htm-to-string",
  "author": "Pelle Wessman <pelle@kodfabrik.se> (http://kodfabrik.se/)",
  "license": "0BSD",
  "repository": {
    "type": "git",
    "url": "git://github.com/voxpelli/async-htm-to-string.git"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "engines": {
    "node": "^22.13.0 || >=24.0.0",
    "typescript": ">=5.8"
  },
  "keywords": [
    "tagged template",
    "template literals",
    "htm",
    "html",
    "async",
    "asyncgenerator",
    "asynciterator",
    "asynciterable",
    "promise",
    "server-side rendering",
    "ssr"
  ],
  "files": [
    "index.d.ts.map",
    "index.d.ts",
    "index.js",
    "lib/**/*.d.ts.map",
    "lib/**/*.d.ts",
    "lib/**/*.js",
    "lib/**/*.mjs"
  ],
  "scripts": {
    "build:0-clean": "run-s clean",
    "build:1-declaration": "tsc -p declaration.tsconfig.json",
    "build:2-types": "node scripts/patch-types.mjs",
    "build": "run-s build:*",
    "build-for-test": "run-s build",
    "check:0": "run-s clean build",
    "check:1:installed-check": "installed-check",
    "check:1:knip": "knip",
    "check:1:lint": "eslint --report-unused-disable-directives .",
    "check:1:skypack": "package-check",
    "check:1:tsc": "tsc",
    "check:1:type-coverage": "type-coverage --detail --strict --at-least 99 --ignore-files 'test/*' --ignore-files 'typetests/*'",
    "check:1": "run-p check:1:*",
    "check:2": "run-s build && tstyche --reporters ./node_modules/@voxpelli/tstyche-reporters/lib/tstyche-mocha-reporter.js,summary && run-s clean",
    "check": "run-s check:*",
    "clean:declarations-top": "rm -rf $(find . -maxdepth 1 -type f -name '*.d.ts*' ! -name 'index.d.ts')",
    "clean:declarations-lib": "rm -rf $(find lib -type f -name '*.d.ts*' ! -name '*-types.d.ts')",
    "clean": "run-p clean:*",
    "prepare": "husky",
    "prepublishOnly": "run-s build",
    "test-ci": "run-s test:*",
    "test": "run-s check test:*",
    "watch:build": "nodemon -x \"run-s build\"",
    "watch": "run-p watch:*",
    "test:node": "node --test --experimental-test-coverage test/**/*.spec.js",
    "test:tstyche": "run-s build && tstyche --target \"$(jq -r \".engines.typescript\" package.json)\" --reporters ./node_modules/@voxpelli/tstyche-reporters/lib/tstyche-mocha-reporter.js,summary && run-s clean",
    "watch:tstyche": "nodemon -e ts -x \"run-s test:tstyche\""
  },
  "dependencies": {
    "@voxpelli/async-iterable-to-string": "workspace:*",
    "@voxpelli/html-render-utils": "workspace:*",
    "@voxpelli/typed-utils": "^3.0.0",
    "@voxpelli/type-helpers": "^4.0.1",
    "buffered-async-iterable": "^1.0.1",
    "htm": "^3.1.1",
    "stringify-entities": "^4.0.4"
  },
  "devDependencies": {
    "@skypack/package-check": "^0.2.2",
    "@types/node": "^20.19.30",
    "@voxpelli/eslint-config": "^23.0.0",
    "@voxpelli/tsconfig": "^16.1.0",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "installed-check": "^9.3.0",
    "knip": "^5.82.1",
    "nodemon": "^3.1.11",
    "npm-run-all2": "^8.0.4",
    "type-coverage": "^2.29.7",
    "typescript": "~5.9.3",
    "validate-conventional-commit": "^1.0.4",
    "@voxpelli/tstyche-reporters": "^1.0.0",
    "tstyche": "^6.2.0"
  },
  "type": "module"
}